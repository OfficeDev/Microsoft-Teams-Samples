{
  "name": "tab-stage-view",
  "version": "1.0.0",
  "description": "Microsoft Teams tab sample app for stage view",
  "main": "server/index.js",
  "scripts": {
    "dev:teamsfx": "npm run dev",
    "dev": "nodemon --inspect=9239 --signal SIGINT server/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server/index.js",
    "watch": "nodemon server/index.js",
    "build": "node build.js",
    "lint": "eslint .",
    "server": "npm install && node server/index.js",
    "manifest": "del \"appManifest\\appManifest.zip\" 2> nul && powershell Compress-Archive appManifest/* appManifest/appManifest.zip"
  },
  "keywords": [],
  "author": "Microsoft",
  "license": "MIT",
  "dependencies": {
    "botbuilder": "^4.23.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "esbuild": "^0.25.0"
  }
}
