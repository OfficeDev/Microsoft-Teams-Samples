{
    "name": "northwindproducts",
    "version": "1.0.0",
    "description": "Microsoft Teams Toolkit message extension search sample",
    "engines": {
        "node": "18 || 20 || 22 || 24"
    },
    "author": "Microsoft",
    "license": "MIT",
    "main": "./lib/src/index.js",
    "scripts": {
        "dev:teamsfx": "env-cmd --silent -f .localConfigs npm run dev",
        "dev": "nodemon --exec node --inspect=9239 --ignore _storage_emulator/ --signal SIGINT -r ts-node/register ./src/index.ts",
        "build": "tsc --build",
        "start": "node ./lib/src/index.js",
        "storage": "azurite --silent --location ./_storage_emulator --debug ./_storage_emulator/debug.log",
        "test": "echo \"Error: no test specified\" && exit 1",
        "watch": "nodemon --exec \"npm run start\""
    },
    "repository": {
        "type": "git",
        "url": "https://github.com"
    },
    "dependencies": {
        "@azure/data-tables": "^13.3.2",
        "@microsoft/adaptivecards-tools": "^1.3.11",
        "adaptive-expressions": "^4.23.3",
        "adaptivecards": "^3.0.6",
        "adaptivecards-templating": "2.3.1",
        "botbuilder": "^4.23.3",
        "restify": "^11.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@types/restify": "^8.5.12",
        "azurite": "^3.35.0",
        "env-cmd": "^11.0.0",
        "nodemon": "^3.1.14",
        "shx": "^0.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}
