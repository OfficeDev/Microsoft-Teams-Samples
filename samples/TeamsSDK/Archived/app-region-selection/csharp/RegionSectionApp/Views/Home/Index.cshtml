@model Microsoft.BotBuilderSamples.Models.RootObject
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Region Selection</title>
    <script src="https://res.cdn.office.net/teams-js/2.34.0/js/MicrosoftTeams.min.js"
            integrity="sha384-brW9AazbKR2dYw2DucGgWCCcmrm2oBFV4HQidyuyZRI/TnAkmOOnTARSTdps3Hwt"
            crossorigin="anonymous"></script>
    <script type="text/javascript" src="~/Scripts/teamsapp.js"></script>
</head>
<body>
    <div class="font-semibold font-title">
        <h3>Welcome to Region Selection App!</h3>
    </div>

    <p>
        <div>
            This will help you to choose your data center's Region.
        </div>
    </p>

    <p>
        <div>
            <label for="domainChoice">Select the data center Region you would like to set: </label>

            <select id="domainChoice" name="domainChoice">
                <option value="" selected="selected">(Select a region)</option>
                @if (Model?.RegionDomains != null)
                {
                    @foreach (var item in Model.RegionDomains)
                    {
                        <option value="@item.Region">@(item.Country + " - " + item.Region)</option>
                    }
                }
            </select>
        </div>
    </p>
</body>
</html>


