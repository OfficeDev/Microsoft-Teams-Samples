{
  "name": "expert-finder-js",
  "version": "1.0.0",
  "msteams": {
    "teamsAppId": null
  },
  "description": "Microsoft Teams message extension that can be used as a plugin to Search for candidates and share profiles matching a criteria.",
  "engines": {
    "node": ">=18"
  },
  "author": "Microsoft",
  "license": "MIT",
  "main": "./src/index.js",
  "scripts": {
    "dev:teamsfx": "node ./scripts/run-with-env.js .localConfigs npm run dev",
    "dev": "nodemon --inspect=9239 --signal SIGINT ./src/index.js",
    "start": "node ./src/index.js",
    "watch": "nodemon ./src/index.js"
  },
  "dependencies": {
    "azure-storage": "^2.10.7",
    "botbuilder": "^4.23.3",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
