{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Microsoft-Teams-Samples.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "outlook",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "prettier": "office-addin-lint prettier",
    "start": "office-addin-debugging start ../appManifest/build/appManifest.local.zip",
    "stop": "office-addin-debugging stop ../appManifest/build/manifest.local.json",
    "validate": "office-addin-manifest validate ../appManifest/build//manifest.local.json",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.8",
    "core-js": "^3.49.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "regenerator-runtime": "^0.14.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/office-js-preview": "^1.0.707",
    "@types/office-runtime": "^1.0.37",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "acorn": "^8.16.0",
    "babel-loader": "^10.1.1",
    "eslint-plugin-office-addins": "^4.0.9",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "office-addin-cli": "^2.0.9",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.9",
    "office-addin-lint": "^3.0.9",
    "office-addin-manifest": "^2.1.5",
    "office-addin-prettier-config": "^2.0.4",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "ts-loader": "^9.5.7",
    "typescript": "^5.8.3",
    "webpack": "^5.107.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "ie 11"
  ]
}
