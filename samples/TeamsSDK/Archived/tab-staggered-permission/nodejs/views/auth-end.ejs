<script src="https://res.cdn.office.net/teams-js/2.52.0/js/MicrosoftTeams.min.js"
  integrity="sha384-j4GNIru3mNYN+q8XdBRVyvbUx+0U867Cy90v6H61tpIZoR2pUq+bZDZmmpT8N7VG"
  crossorigin="anonymous"></script>
<script type="text/javascript" src="https://alcdn.msauth.net/browser/5.8.0/js/msal-browser.min.js"></script>
 <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', () => {
        getAuthToken();
    });

    // Get auth token.
    function getAuthToken() {
        microsoftTeams.app.initialize().then(() => {
            microsoftTeams.app.getContext().then(async () => {
                const data = <%-data%>;
                const msalConfig = {
                    auth: {
                        clientId: data.clientId,
                        authority: `https://login.microsoftonline.com/${data.tenantId}`,
                        navigateToLoginRequestUrl: false
                    },
                    cache: {
                        cacheLocation: "sessionStorage",
                    },
                };
				
                const msalInstance = new window.msal.PublicClientApplication(msalConfig);
                await msalInstance.initialize();
				
                msalInstance.handleRedirectPromise()
                    .then((tokenResponse) => {
                        if (tokenResponse !== null) {
                            microsoftTeams.authentication.notifySuccess("Authentication succedded");
                        } else {
                            microsoftTeams.authentication.notifyFailure("Get empty response.");
                        }
                    })
                    .catch((error) => {
                        microsoftTeams.authentication.notifyFailure(JSON.stringify(error));
                    });
            });
        });
    }
</script>