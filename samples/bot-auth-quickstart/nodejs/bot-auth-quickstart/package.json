{
    "name": "bot-auth-quickstart",
    "version": "1.0.0",
    "description": "Microsoft 365 Agents Toolkit Bot-Auth-Quickstart Sample",
    "author": "Microsoft",
    "license": "MIT",
    "main": "./lib/app.js",
    "scripts": {
        "dev:teamsfx": "env-cmd --silent -f .localConfigs npm run dev",
        "dev": "nodemon --exec node --inspect=9239 --signal SIGINT -r ts-node/register ./app.ts",
        "build": "tsc --build",
        "start": "node ./lib/app.js",
        "watch": "nodemon --exec \"npm run start\"",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/OfficeDev/Microsoft-Teams-Samples"
    },
    "dependencies": {
        "@microsoft/teams.api": "^2.0.0",
        "@microsoft/teams.apps": "^2.0.0",
        "@microsoft/teams.graph-endpoints": "^2.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "env-cmd": "^10.1.0",
        "nodemon": "^3.1.7",
        "ts-node": "^10.4.0",
        "typescript": "~5.8.3"
    }
}
