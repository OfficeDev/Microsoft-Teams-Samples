{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Microsoft.Teams": {
      "Enable": "*",
      "Level": "debug"
    }
  },
  "AllowedHosts": "*",
  "Teams": {
		"ClientId": "$botId$",
		"ClientSecret": "$bot-password$",
		"BotType": "UserAssignedMsi"
	}
}