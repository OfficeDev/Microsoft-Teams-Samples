{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Microsoft",
        "websiteUrl": "https://www.microsoft.com",
        "privacyUrl": "https://www.microsoft.com/privacy",
        "termsOfUseUrl": "https://www.microsoft.com/termsofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "App task reminder",
        "full": "App task reminder"
    },
    "description": {
        "short": "Teams bot to schedule recurring tasks and receive reminders at set times.",
        "full": "This bot allows users to schedule recurring tasks and receive reminders in Teams."
    },
    "accentColor": "#60A18E",
    "bots": [
        {
        "botId": "${{BOT_ID}}",
        "scopes": ["personal"],
        "isNotificationOnly": false,
        "commandLists": [
                {
                  "scopes": ["personal"],
                  "commands": [
                      {
                          "title": "create-reminder",
                          "description": "To create the reminder for a task"
                      }
                  ]
                }
            ]
        }
    ],
    "composeExtensions": [],
    "configurableTabs": [],
    "staticTabs": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "${{BOT_DOMAIN}}"
    ]
}
