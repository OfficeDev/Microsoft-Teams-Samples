<!DOCTYPE html>
<html lang="en">

<head>
    <script src="../MicrosoftTeams.min.js"
        integrity="sha384-h+MoYshcGDPMLlXjHLt2dSgsgYyWQ+yHd4Ob13htDsu8trGPea8Vooa8+tLtRzU7"
        crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline';" />
    <title>Configure Page</title>
    <style>
        body {
            font-family: "Segoe UI", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Web";
        }

        .config-container {
            padding: 0.5rem;
        }
    </style>

    <script>
        const allowedTenantId = '<%= allowedTenantId %>'.trim().toLowerCase();
        let currentTenantId = '';

        microsoftTeams.app.initialize().then(() => {
            microsoftTeams.app.getContext().then((context) => {
                currentTenantId = (context?.user?.tenant?.id || context?.tid || '').toLowerCase();

                if (allowedTenantId && currentTenantId && allowedTenantId !== currentTenantId) {
                    microsoftTeams.pages.config.setValidityState(false);
                    document.getElementById('error_message').innerHTML = 'This app is configured for a different tenant.';
                    return;
                }
            });

            microsoftTeams.pages.config.registerOnSaveHandler((saveEvent) => {
                if (allowedTenantId && currentTenantId && allowedTenantId !== currentTenantId) {
                    saveEvent.notifyFailure('Invalid tenant.');
                    return;
                }

                var myHeaders = new Headers();
                myHeaders.append('Content-Type', 'application/json');
                myHeaders.append('x-tenant-id', currentTenantId);

                var requestOptions = {
                    method: 'POST',
                    headers: myHeaders,
                    body: JSON.stringify({
                        CartUrl: document.getElementById("cart-url").value
                    })
                };

                fetch(`${window.location.origin}/api/meeting/SaveCARTUrl`, requestOptions)
                    .then(response => {
                        if (response.status === 200) {
                            microsoftTeams.pages.config.setConfig({
                                entityId: 'caption-tab',
                                contentUrl: window.location.origin + '/Home/Index',
                                suggestedDisplayName: 'Meeting Live Caption'
                            });
                            saveEvent.notifySuccess();
                        }
                        else {
                            saveEvent.notifyFailure("");
                        }
                    })
                    .catch(error => saveEvent.notifyFailure(error));
            });
        });

        function onCARTInputChange(url) {
            var errorSpan = document.getElementById('error_message');

            if (allowedTenantId && currentTenantId && allowedTenantId !== currentTenantId) {
                microsoftTeams.pages.config.setValidityState(false);
                document.getElementById('success_message').hidden = true;
                errorSpan.innerHTML = 'This app is configured for a different tenant.';
                return;
            }

            if (url != null && url.trim() !== '' && url.includes('meetingid') && url.includes('token')) {
                microsoftTeams.pages.config.setValidityState(true);
                errorSpan.innerHTML = '';
                document.getElementById('success_message').hidden = false;
            }
            else {
                microsoftTeams.pages.config.setValidityState(false);
                document.getElementById('success_message').hidden = true;
                errorSpan.innerHTML = 'Please enter a valid CART URL.';
            }
        }
    </script>
</head>

<body>
    <div class="config-container">
        <h2>
            Please enter CART URL of the meeting to proceed:
        </h2>
        Click on this link to know <a target="_blank"
            href="https://support.microsoft.com/office/use-cart-captions-in-a-microsoft-teams-meeting-human-generated-captions-2dd889e8-32a8-4582-98b8-6c96cf14eb47">how
            to get Meeting CART URL.</a>
        <input style="width:96%;" type="text" id="cart-url" oninput="onCARTInputChange(this.value)" /><span id="error_message"
            style="color:red;margin-left:1rem;"></span>
        <p style="color:green" id="success_message" hidden>Click on save to configure the tab.</p>
    </div>
</body>

</html>