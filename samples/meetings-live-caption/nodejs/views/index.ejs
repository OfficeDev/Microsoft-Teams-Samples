<!DOCTYPE html>
<html lang="en">

<head>
    <script src="../MicrosoftTeams.min.js"
        integrity="sha384-h+MoYshcGDPMLlXjHLt2dSgsgYyWQ+yHd4Ob13htDsu8trGPea8Vooa8+tLtRzU7"
        crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <!-- <meta http-equiv="Content-Security-Policy" content="default-src *; style-src 'self' 'unsafe-inline' http://localhost:3978; script-src 'self' 'unsafe-inline' 'unsafe-eval'"> -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline';" />


    <title>Meeting Live Caption</title>
    <link rel="stylesheet" href="../style.css">
    <style>
        body {
            font-family: "Segoe UI", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Web";
        }

        .container {
            color: cornflowerblue;
            font-weight: bold;
            padding: 0.5rem;
        }

        .submit-button {
            font-weight: 600;
            background-color: #5B58C7;
            padding: 0.5rem 1.5rem;
            color: white;
            border-radius: 7px;
            border: none;
            cursor: pointer;
        }

        .submit-button:hover {
            background-color: #7A80EB;
        }
    </style>
    <script type="text/javascript">
        const allowedTenantId = '<%= allowedTenantId %>'.trim().toLowerCase();
        let currentTenantId = '';

        document.addEventListener('DOMContentLoaded', function () {
            microsoftTeams.app.initialize().then(() => {
                microsoftTeams.app.getContext().then((context) => {
                    var infoDiv = document.getElementById('show-info');
                    var form = document.getElementById('caption-form');

                    currentTenantId = (context?.user?.tenant?.id || context?.tid || '').toLowerCase();
                    infoDiv.style.color = context.app.theme === 'default' ? 'black' : 'white';

                    if (allowedTenantId && currentTenantId && allowedTenantId !== currentTenantId) {
                        infoDiv.innerHTML = 'This app is configured for a different tenant.';
                        form.hidden = true;
                        return;
                    }

                    if (context.page.frameContext !== 'sidePanel') {
                        infoDiv.innerHTML = 'Please open this application in meeting side panel.';
                        form.hidden = true;
                    } else {
                        infoDiv.innerHTML = '';
                        form.hidden = false;
                    }
                });
            });
        });

        function onSubmitCaption() {
            var captionInput = document.getElementById('caption');
            var loader = document.getElementById('loader');
            var captionText = captionInput.value.trim();

            if (captionText === '') {
                return;
            }

            loader.hidden = false;

            var headers = new Headers();
            headers.append('Content-Type', 'application/json');
            headers.append('x-tenant-id', currentTenantId);

            var requestOptions = {
                method: 'POST',
                headers,
                body: JSON.stringify({
                    captionText
                }),
                redirect: 'follow'
            };

            fetch(`${window.location.origin}/api/meeting/LiveCaption`, requestOptions)
                .then((response) => {
                    loader.hidden = true;
                    if (response.status === 200) {
                        captionInput.value = '';
                    }
                })
                .catch((error) => {
                    loader.hidden = true;
                    console.log('error', error);
                });
        }

        function onTextAreaKeyPress(event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                onSubmitCaption();
            }
        }
    </script>
</head>

<body>
    <div class="container">
        <div id="show-info"></div>
        <form id="caption-form" onsubmit="event.preventDefault()">
            <label for="caption">Input caption here:</label><br>
            <textarea onkeypress="onTextAreaKeyPress(event)" style="min-height:4rem;width:100%;" id="caption"></textarea>
            <span style="font-size:12px;">Press Enter or Submit to send</span>
            <div style="display:flex;">
                <button class="submit-button" onclick="onSubmitCaption()">Submit</button>
                <div hidden id="loader"></div>
            </div>
        </form>
    </div>

</body>

</html>